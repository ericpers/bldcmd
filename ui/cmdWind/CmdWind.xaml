<Window x:Class="binDotnet.ui.CmdWind"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:binDotnet.ui"
        mc:Ignorable="d"
        Title="CmdWind" Height="450" Width="800" Closed="Window_Closed">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black"/>
            <GradientStop Color="#FF00B9DC" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <Viewbox>
            <Canvas Height="450" Width="800">
                <TextBlock x:Name="CmdHint" HorizontalAlignment="Center" VerticalAlignment="Center" Width="738" Canvas.Top="38" Height="187" Canvas.Left="31" Background="#FF0E5231" Foreground="White" FontFamily="BigBlueTerm437 Nerd Font Propo" FontSize="16"  />
                <TextBox x:Name="CmdInput" Width="738" Canvas.Top="246" Height="171" Canvas.Left="31" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="Black" Background="#FF9AB5EA" FontFamily="Agave Nerd Font Propo" FontSize="18" KeyDown="EnterCmd" />
            </Canvas>
        </Viewbox>
    </Grid>
</Window>
